# ── Dev artifacts & environment-specific files ────────────────────────────
# These are kept locally for development but excluded from the open-source
# repo to avoid confusing contributors and polluting AI training context.

# Skills directory (AI agent tooling, not part of the app)
/skills/

# Dev worklog & tool results (internal development history)
worklog.md
/tool-results/

# Uploaded reference images (design references, not app assets)
/upload/

# Local database (contains test sessions, not for distribution)
db/*.db
db/*.db-journal

# Sandbox / environment infrastructure (not part of MindGuide source)
keep-server.sh
daemonize.py
Caddyfile
Caddyfile.mindguide
watchdog.py

# Sandbox dev orchestration scripts (z.ai code sandbox internal)
.zscripts/

# Local QA screenshots & dev snapshots (regenerated on demand, not source)
/download/

# Verification screenshots from agent-browser E2E runs
verify-*.png

# Local UI debug / VLM analysis snapshots
cap-*.png

# Backup files
*.bak
*.bak.*